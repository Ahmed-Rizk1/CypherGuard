{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Pipeline Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(securenet_packets_processed_total{status=\"success\"}[1m])", "legendFormat": "{{service}} processed/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Alert Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(securenet_alerts_total[5m])", "legendFormat": "{{attack_type}} ({{severity}})" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "ML Prediction Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(securenet_prediction_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(securenet_prediction_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(securenet_prediction_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "LLM Analysis Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(securenet_llm_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(securenet_llm_duration_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "LLM Call Outcomes",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "expr": "increase(securenet_llm_calls_total[1h])", "legendFormat": "{{status}}" }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 16 },
      "targets": [
        { "expr": "securenet_circuit_breaker_state{name=\"openrouter\"}", "legendFormat": "LLM Circuit" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "CLOSED ✅", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "HALF_OPEN ⚠️", "color": "yellow" } }, "type": "value" },
            { "options": { "2": { "text": "OPEN 🔴", "color": "red" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Stream Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "securenet_queue_depth", "legendFormat": "{{stream}}" }
      ]
    },
    {
      "title": "Active WebSocket Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "targets": [
        { "expr": "securenet_websocket_connections" }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "thresholds": { "steps": [
        { "value": 0, "color": "green" },
        { "value": 50, "color": "yellow" },
        { "value": 80, "color": "red" }
      ]}}}
    },
    {
      "title": "Blocked IPs Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 24 },
      "targets": [
        { "expr": "securenet_blocked_ips_count" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "value": 0, "color": "green" },
        { "value": 20, "color": "yellow" },
        { "value": 50, "color": "red" }
      ]}}}
    },
    {
      "title": "Auth Events Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "rate(securenet_auth_events_total[5m])", "legendFormat": "{{event}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Decision Queue Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "securenet_decision_queue_size", "legendFormat": "Pending writes" }
      ]
    },
    {
      "title": "Firewall Block Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        { "expr": "rate(securenet_firewall_blocks_total[5m])", "legendFormat": "{{source}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["securenet", "soc", "ids"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SecureNet SOC — Operations Dashboard",
  "uid": "securenet-ops",
  "version": 1
}
