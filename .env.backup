# ===================================================================
# SecureNet SOC — Environment Configuration Template
# ===================================================================
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Replace ALL placeholder values below with real secrets
#   3. NEVER commit the .env file to version control
#
# Generate secrets with:
#   openssl rand -hex 32
#
# ===================================================================

# --- JWT Authentication ---
JWT_SECRET=CHANGE-ME-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600

# --- PostgreSQL ---
POSTGRES_USER=securenet
POSTGRES_PASSWORD=CHANGE-ME-generate-strong-password
POSTGRES_DB=securenet
DATABASE_URL=postgresql+asyncpg://securenet:${POSTGRES_PASSWORD}@localhost:5432/securenet

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM / OpenRouter ---
OPENROUTER_API_KEY=CHANGE-ME-get-from-openrouter-dashboard
LLM_MODEL=meta-llama/llama-3-8b-instruct:free
LLM_TIMEOUT=30

# --- Internal Service Auth ---
INTERNAL_API_KEY=CHANGE-ME-use-openssl-rand-hex-32

# --- Logging ---
LOG_LEVEL=INFO

# --- Mobile Gateway ---
MOBILE_DECISION_TIMEOUT=60

# --- Firewall ---
ENABLE_OS_FIREWALL=0

# --- Feature Extraction ---
FEATURE_WINDOW_SECONDS=30
METRICS_PUBLISH_INTERVAL=1.0

# --- Fallback Scanner ---
FALLBACK_SCANNER_INTERVAL=10.0

# --- TLS / Domain (production profile) ---
DOMAIN=securenet.example.com
ACME_EMAIL=admin@example.com

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE-ME-strong-grafana-password

# --- Chaos Engineering (NEVER enable in production) ---
CHAOS_MODE=false

# --- Feature Drift Detection ---
DRIFT_BASELINE_PATH=ml_engine/models/feature_baselines.json

# --- Redis Sentinel (enable redis-ha profile) ---
# REDIS_SENTINEL_URL=sentinel://redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379/mymaster

# --- Resource Limits (for reference in docker-compose.prod.yml) ---
# ML_ENGINE_MEMORY_LIMIT=1G
# GATEWAY_MEMORY_LIMIT=512M
# POSTGRES_SHARED_BUFFERS=256MB

# ===================================================================
# SaaS Configuration (Multi-Tenant)
# ===================================================================

# --- Stripe Billing ---
STRIPE_SECRET_KEY=sk_test_CHANGE-ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE-ME
STRIPE_PRICE_PRO=price_CHANGE-ME-pro-monthly
STRIPE_PRICE_BUSINESS=price_CHANGE-ME-business-monthly
STRIPE_PRICE_ENTERPRISE=price_CHANGE-ME-enterprise-monthly

# --- Email / SMTP ---
# Leave SMTP_HOST empty for console-based email (development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@securenet.io

# --- Application URL ---
APP_URL=http://localhost:5173

# --- Sensor API Key (for local sensor testing) ---
SENSOR_API_KEY=

# --- Trial Configuration ---
TRIAL_CHECK_INTERVAL=3600

